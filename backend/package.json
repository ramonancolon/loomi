{
  "name": "chromaflow-backend",
  "version": "1.0.0",
  "description": "ChromaFlow Multimodal Brand Asset Orchestrator - Backend API with Temporal",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "dev": "ts-node src/index.ts",
    "dev:worker": "ts-node src/worker.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage"
  },
  "vitest": {
    "globals": true,
    "environment": "node",
    "include": [
      "src/**/*.test.ts",
      "src/**/*.test.tsx"
    ],
    "exclude": [
      "node_modules",
      "dist"
    ]
  },
  "keywords": [
    "chromaflow",
    "temporal",
    "express",
    "ai",
    "creative"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@temporalio/testing": "^1.17.2",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.41",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^1.2.1",
    "@vitest/ui": "^1.2.1",
    "nodemon": "^3.0.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^8.0.15",
    "vitest": "^1.2.1"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@temporalio/client": "^1.17.2",
    "@temporalio/worker": "^1.17.2",
    "@temporalio/workflow": "^1.17.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  }
}
