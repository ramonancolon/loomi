# Copy to backend/.env for local dev: cp .env.example .env

PORT=3001
NODE_ENV=development

# Temporal Cloud (from cloud.temporal.io → your namespace)
TEMPORAL_ADDRESS=your-namespace.a1b2c.tmprl.cloud:7233
TEMPORAL_NAMESPACE=your-namespace.a1b2c
TEMPORAL_API_KEY=your-temporal-cloud-api-key
TEMPORAL_TASK_QUEUE=chromaflow-task-queue

# Public API + OAuth (local)
PUBLIC_API_BASE_URL=http://localhost:3001
MCP_OAUTH_REDIRECT_URL=http://localhost:3001/api/mcp/auth/callback
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# AI (required for live MCP reasoning)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
REPLICATE_API_KEY=

# Bloomreach MCP (sandbox)
ENGAGEMENT_URL=https://uqa.app.exponea.dev/p/noisy-muffin
MCP_MARKETING_URL=https://loomi-mcp-alpha.bloomreach.com/mcp
MCP_CONVERSATION_URL=https://uqa.api.exponea.dev/cocoaas/public/api/clarity-search/v1/mcp/019d4917-3c76-7479-9f00-06c620b231bb
