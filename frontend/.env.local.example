# Copy to .env.local: cp .env.local.example .env.local
#
# Next.js runs on :3000; Express API runs on :3001.
# BACKEND_URL       → Next server proxies to Express (not exposed to browser)
# NEXT_PUBLIC_*     → Browser MCP sign-in link (OAuth callback is on :3001)

BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
