# Copy to .env on the EC2 host: cp .env.ec2.example .env

# --- Public URLs (replace YOUR_EC2_PUBLIC_IP with your instance IP) ---
FRONTEND_PORT=3000
BACKEND_PORT=3001

# Backend .env (Express + OAuth callback)
PUBLIC_API_BASE_URL=http://YOUR_EC2_PUBLIC_IP:3001
MCP_OAUTH_REDIRECT_URL=http://YOUR_EC2_PUBLIC_IP:3001/api/mcp/auth/callback
CORS_ALLOWED_ORIGINS=http://YOUR_EC2_PUBLIC_IP:3000
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP:3000

# Frontend Docker build (browser MCP sign-in; baked into Next at build time)
NEXT_PUBLIC_API_BASE_URL=http://YOUR_EC2_PUBLIC_IP:3001
# Note: BACKEND_URL for the frontend container is set in docker-compose.ec2.yml
# as http://backend:3001 (internal Docker network, not this file).

# --- Temporal Cloud (recommended on a single EC2) ---
# From cloud.temporal.io → Namespaces → gRPC endpoint + namespace id (e.g. quickstart-abc.x7y8z)
TEMPORAL_ADDRESS=your-namespace.a1b2c.tmprl.cloud:7233
TEMPORAL_NAMESPACE=your-namespace.a1b2c
TEMPORAL_API_KEY=your-temporal-cloud-api-key
TEMPORAL_TASK_QUEUE=chromaflow-task-queue

# --- AI (required for live MCP reasoning) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
REPLICATE_API_KEY=

# --- Bloomreach MCP (sandbox) ---
ENGAGEMENT_URL=https://uqa.app.exponea.dev/p/noisy-muffin
MCP_MARKETING_URL=https://loomi-mcp-alpha.bloomreach.com/mcp
MCP_CONVERSATION_URL=https://uqa.api.exponea.dev/cocoaas/public/api/clarity-search/v1/mcp/019d4917-3c76-7479-9f00-06c620b231bb
